<Project>

  <!--
    BenchmarkDotNet は実行時に bin 配下へ Autogenerated プロジェクトを生成し、ビルドして別プロセスで走らせる。
    MSBuild は最寄りの Directory.Build.props だけを自動 import するため、この props が存在しないと
    Autogenerated プロジェクトはリポジトリルートの Directory.Build.props を継承してしまう。
    ルートの props は複数 TargetFrameworks (net10.0;net8.0;netstandard2.1;netstandard2.0;net47) や
    パッケージ生成設定を持つため、それを継承すると net10.0 単一の Benchmark プロジェクトと噛み合わずビルドが失敗する。

    そこでベンチマークのサブツリーではルート props を継承せず、必要な共通設定だけをここで定義する。
    (親を import しないことで TargetFrameworks 等の漏れ込みを止めている)
  -->
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
  </PropertyGroup>

</Project>
